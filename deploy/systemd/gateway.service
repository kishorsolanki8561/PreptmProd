[Unit]
Description=PreptM API Gateway (Ocelot)
After=network.target

[Service]
WorkingDirectory=/var/www/preptm/api/gateway
ExecStart=/usr/bin/dotnet Gateway.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=preptm-gateway
User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://localhost:5000
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
